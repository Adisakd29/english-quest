# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้ามอัปโหลด .env ขึ้น GitHub)

# Railway จะสร้างตัวแปรนี้ให้อัตโนมัติเมื่อคุณเพิ่ม PostgreSQL plugin
# ตอนรันบนเครื่องตัวเอง ให้ใส่ connection string ของ Postgres ที่คุณมี
DATABASE_URL=postgresql://user:password@localhost:5432/englishquest

# กุญแจลับสำหรับเข้ารหัส JWT token (เปลี่ยนเป็นข้อความสุ่มยาว ๆ ของตัวเอง)
JWT_SECRET=change-this-to-a-long-random-secret-string

# พอร์ตสำหรับรันเซิร์ฟเวอร์ (Railway จะกำหนดให้เองผ่าน PORT)
PORT=3000

# ใส่ "production" เมื่อ deploy จริง
NODE_ENV=development
